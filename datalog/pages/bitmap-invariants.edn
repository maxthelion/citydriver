 ;; Pass 3 — Decisions
 [:db/add -6 :decision/summary "Invariants should be checked at every pipeline step, not just at the end."]
 [:db/add -6 :decision/rationale "A violation introduced at step 3 is much easier to diagnose when caught at step 3 than when it causes a rendering glitch at step 7."]
 [:db/add -6 :decision/affects -1]

 [:db/add -7 :decision/summary "The grid must be derived from the polyline, never computed independently (polyline-grid agreement)."]
 [:db/add -7 :decision/rationale "One source of truth (the polyline), grid derived from it. Violations happen when grid is stamped from raw A* path vs simplified polyline, or two code paths stamp the same grid."]
 [:db/add -7 :decision/affects -1]

 [:db/add -8 :decision/summary "Sampled checks or GPU acceleration for performance on large grids."]
 [:db/add -8 :decision/rationale "Full 1200x1200 grid checks (1.4M cells) across multiple seeds could be slow; sampling catches most violations at O(1/N) cost."]
 [:db/add -8 :decision/affects -1]

