 ;; Pass 3 — Decisions
 [:db/add -5 :decision/summary "Primary GPU acceleration target is growth:value (22% of total time), which is embarrassingly parallel per-cell multiply-add."]
 [:db/add -5 :decision/rationale "composeAllValueLayers iterates 1.44M cells per layer per agent per tick. GPU dispatch eliminates this step (<1ms)."]
 [:db/add -5 :decision/affects -1]

 [:db/add -6 :decision/summary "Skip zones-refine when zone-boundary added no roads."]
 [:db/add -6 :decision/rationale "The second facesWithEdges() call is expensive and unnecessary when no new edges were added."]
 [:db/add -6 :decision/affects -1]

 [:db/add -7 :decision/summary "Use separated 1D blur passes instead of 2D kernels for spatial computations."]
 [:db/add -7 :decision/rationale "Reduces road frontage blur from O(n*r^2) to O(n*2r), and flatness kernel from O(n*49) to O(n*14)."]
 [:db/add -7 :decision/affects -1]

