 ;; Pass 3 — Decisions
 [:db/add -9 :decision/summary "Cities inherit terrain, rivers, water, and settlement positions from the regional map rather than generating from scratch."]
 [:db/add -9 :decision/rationale "Ensures causal consistency between regional and city scales."]
 [:db/add -9 :decision/affects -1]

 [:db/add -10 :decision/summary "Pipeline implemented as a JavaScript generator yielding step descriptors, not a state machine."]
 [:db/add -10 :decision/rationale "Enables named steps, hook-based observability, and composeable growth strategies via yield*."]
 [:db/add -10 :decision/affects -1]

 [:db/add -11 :decision/summary "Zone extraction runs twice: once before and once after zone boundary roads."]
 [:db/add -11 :decision/rationale "The second extraction picks up finer faces created by the new boundary roads."]
 [:db/add -11 :decision/affects -1]

 [:db/add -12 :decision/summary "For archetypes without growth config, three simple steps (reserve, ribbons, connect) replace the organic growth loop."]
 [:db/add -12 :decision/rationale "Only marketTown currently uses organic growth; others use BFS-based reservation."]
 [:db/add -12 :decision/affects -1]

