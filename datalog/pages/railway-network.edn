 ;; Pass 3 — Decisions
 [:db/add -6 :decision/summary "Railways are planned infrastructure built in historical phases, unlike organically growing roads."]
 [:db/add -6 :decision/rationale "Reflects real history: main trunk lines first, secondary trunks, branch lines, then cross-country routes."]
 [:db/add -6 :decision/affects -1]

 [:db/add -7 :decision/summary "Terminus stations are fan-shaped, not radial — lines converge from one direction then spread into parallel platforms."]
 [:db/add -7 :decision/rationale "Unlike roads which radiate from a centre, railway lines approach from a concentrated direction."]
 [:db/add -7 :decision/affects -1]

 [:db/add -8 :decision/summary "Railway cost function heavily penalises slope (10x more than roads) with max 2-3% gradient."]
 [:db/add -8 :decision/rationale "Real railways need very gradual elevation change, preferring valleys and gentle curves over direct routes."]
 [:db/add -8 :decision/affects -1]

